{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "docs",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.2",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low",
            "reasoningSummary": "concise"
          }
        },
        "gpt-5.2": {
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "concise"
          }
        },
        "gpt-5.3-codex": {
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "concise"
          }
        },
        "gpt-5.1-codex-mini": {
          "options": {
            "reasoningEffort": "minimal",
            "textVerbosity": "low",
            "reasoningSummary": "concise"
          }
        }
      }
    }
  },
  "agent": {
    "coding-boss": {
      "description": "Routes coding work by phase",
      "mode": "primary",
      "color": "#BEEE62",
      "model": "openai/gpt-5.2",
      "prompt": "{file:./prompts/coding-boss.txt}",
      "permission": {
        "task": {
          "*": "deny",
          "planner": "allow",
          "implementer-small": "allow",
          "implementer": "allow",
          "code-reviewer": "allow"
        },
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      }
    },
    "planner": {
      "description": "Creates compact execution-ready plans",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/planner.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": "ask"
      }
    },
    "implementer-small": {
      "description": "Cheap execution agent for trivial tasks",
      "mode": "subagent",
      "model": "openai/gpt-5.1-codex-mini",
      "prompt": "{file:./prompts/implementer-small.txt}",
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      }
    },
    "implementer": {
      "description": "Primary implementation agent",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/implementer.txt}",
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      }
    },
    "code-reviewer": {
      "description": "Reviews implementation",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/code-reviewer.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": "ask"
      }
    },
    "docs": {
      "description": "Documentation router",
      "mode": "primary",
      "color": "#D74E09",
      "model": "openai/gpt-5.2",
      "prompt": "{file:./prompts/docs.txt}",
      "permission": {
        "task": {
          "*": "deny",
          "docs-planner": "allow",
          "docs-writer-fast": "allow",
          "docs-reviewer": "allow",
          "agent-architect": "allow"
        },
        "write": "allow",
        "edit": "allow"
      }
    },
    "docs-planner": {
      "description": "Plans documentation work",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/docs-planner.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny"
      }
    },
    "docs-writer-fast": {
      "description": "Documentation execution agent",
      "mode": "subagent",
      "model": "openai/gpt-5.2",
      "prompt": "{file:./prompts/docs-writer-fast.txt}",
      "permission": {
        "write": "allow",
        "edit": "allow"
      }
    },
    "docs-reviewer": {
      "description": "Reviews documentation",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/docs-reviewer.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny"
      }
    },
    "agent-architect": {
      "description": "Designs AGENTS.md",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/agent-architect.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny"
      }
    }
  }
}