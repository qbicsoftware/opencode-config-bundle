{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "docs",
  "model": "opencode/claude-sonnet-4-6",
  "small_model": "opencode/claude-haiku-4-5",
  "agent": {
    "coding-boss": {
      "description": "Routes coding work by phase: planning, trivial implementation, normal implementation, and review",
      "mode": "primary",
      "color": "#BEEE62",
      "model": "opencode/claude-sonnet-4-6",
      "prompt": "{file:./prompts/coding-boss.txt}",
      "permission": {
        "task": {
          "*": "deny",
          "planner": "allow",
          "implementer-small": "allow",
          "implementer": "allow",
          "code-reviewer": "allow"
        },
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      }
    },
    "planner": {
      "description": "Produces structured implementation plans",
      "mode": "subagent",
      "model": "opencode/claude-sonnet-4-6",
      "prompt": "{file:./prompts/planner.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": "ask"
      }
    },
    "implementer-small": {
      "description": "Cheap execution agent for trivial tasks",
      "mode": "subagent",
      "model": "opencode/gpt-5.1-codex-mini",
      "prompt": "{file:./prompts/implementer-small.txt}",
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      }
    },
    "implementer": {
      "description": "Primary implementation agent",
      "mode": "subagent",
      "model": "opencode/gpt-5.3-codex",
      "prompt": "{file:./prompts/implementer.txt}",
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow"
      }
    },
    "code-reviewer": {
      "description": "Reviews implementation for quality and safety",
      "mode": "subagent",
      "model": "opencode/claude-sonnet-4-6",
      "prompt": "{file:./prompts/code-reviewer.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": "ask"
      }
    },
    "docs": {
      "description": "Documentation router",
      "mode": "primary",
      "color": "#D74E09",
      "model": "opencode/claude-haiku-4-5",
      "prompt": "{file:./prompts/docs.txt}",
      "permission": {
        "task": {
          "*": "deny",
          "docs-planner": "allow",
          "docs-writer-fast": "allow",
          "docs-reviewer": "allow",
          "agent-architect": "allow"
        },
        "write": "allow",
        "edit": "allow"
      }
    },
    "docs-planner": {
      "description": "Documentation planner",
      "mode": "subagent",
      "model": "opencode/claude-sonnet-4-6",
      "prompt": "{file:./prompts/docs-planner.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny"
      }
    },
    "docs-writer-fast": {
      "description": "Cheap documentation writer",
      "mode": "subagent",
      "model": "opencode/claude-haiku-4-5",
      "prompt": "{file:./prompts/docs-writer-fast.txt}",
      "permission": {
        "write": "allow",
        "edit": "allow"
      }
    },
    "docs-reviewer": {
      "description": "Reviews documentation quality",
      "mode": "subagent",
      "model": "opencode/claude-sonnet-4-6",
      "prompt": "{file:./prompts/docs-reviewer.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny"
      }
    },
    "agent-architect": {
      "description": "Designs AGENTS.md multi-agent workflow docs",
      "mode": "subagent",
      "model": "opencode/claude-sonnet-4-6",
      "prompt": "{file:./prompts/agent-architect.txt}",
      "permission": {
        "write": "deny",
        "edit": "deny"
      }
    }
  }
}